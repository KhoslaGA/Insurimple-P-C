# Copy to apps/api/.env — never commit .env.
# Postgres 16. In dev, connect as superuser and set DB_SET_ROLE=app so RLS applies.
DATABASE_URL=postgres://postgres:dev@localhost:5433/insurimple
DB_SET_ROLE=app
PORT=3001

# Clerk. When set, the API REQUIRES a Bearer session token on every request
# (org claim -> tenant.clerk_org_id, sub -> staff.external_auth_id).
# When unset AND NODE_ENV=development, the x-tenant-id/x-actor-id dev headers work.
CLERK_SECRET_KEY=
