{
  "name": "@insurimple/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file-if-exists=.env dist/main.js",
    "dev": "tsc -p tsconfig.json && node --env-file-if-exists=.env dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo 'lint: configured in packages/config (T0.1)'"
  },
  "dependencies": {
    "@clerk/backend": "^3.11.7",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "typescript": "^5.6.0"
  }
}
