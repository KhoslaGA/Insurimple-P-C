# Copy to .env.local for local development. Never commit .env.local.

# Connect as the NON-OWNER role. Connecting as the database owner or a
# superuser bypasses row level security, which would silently show you every
# tenant's data and hide exactly the bugs RLS exists to catch.
DATABASE_URL=postgres://insurimple_app:devpassword@localhost:5432/insurimple_dev

# Stand-in for the Clerk org + subject claims until Clerk is wired up.
# See apps/bms/src/lib/session.ts. These are seeded ids from packages/db/seed.sql.
#   Northpeak (P&C + life) with Maya Lawson, a licensed RIBO broker:
DEV_TENANT_ID=11111111-1111-4111-8111-111111111111
DEV_USER_ID=aaaaaaaa-0000-4000-8000-000000000001

#   Swap to Rideau to prove tenant isolation from the UI — you should see a
#   completely different book, and Northpeak's household should 404:
# DEV_TENANT_ID=22222222-2222-4222-8222-222222222222
# DEV_USER_ID=bbbbbbbb-0000-4000-8000-000000000001
